# ---------------------------------------------------------------------------
# OYPA CRM - ortam degiskenleri ornegi
# Bu dosyayi ".env" olarak kopyalayin ve degerleri doldurun.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# GERCEK secret'lari ASLA repoya commit etmeyin. ".env" .gitignore ile dislanir.
# ---------------------------------------------------------------------------

# SQL Server 'sa' kullanicisi sifresi.
# SQL Server karmasiklik politikasi: en az 8 karakter; buyuk harf, kucuk harf,
# rakam ve sembol iceren guclu bir deger kullanin.
MSSQL_SA_PASSWORD=

# JWT imzalama anahtari (HMAC). EN AZ 32 KARAKTER olmalidir.
# Ornek uretim (PowerShell): [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))
JWT_SECRET=

# Frontend'in API'ye baglanacagi taban URL.
# docker-compose ile varsayilan: http://localhost:5080/api
VITE_API_BASE_URL=http://localhost:5080/api
